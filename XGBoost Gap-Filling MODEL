# ---> MAGIA DO NDVI ACONTECENDO AQUI <---
# 1. Junta as colunas do df_ndvi com a torre (o Pandas alinha as datas automaticamente)
df = df.join(ndvi120[['NDVI_Medio', 'NDVI_Desvio']], how='left')

# 2. Interpola os buracos de meia em meia hora criando uma rampa suave entre os dias de satélite
df['NDVI_Medio'] = df['NDVI_Medio'].interpolate(method='time')
df['NDVI_Desvio'] = df['NDVI_Desvio'].interpolate(method='time')

# 3. Caso tenha sobrado buraco no começo ou no fim da série (antes da 1ª imagem), a gente repete o valor
df['NDVI_Medio'] = df['NDVI_Medio'].bfill().ffill()
df['NDVI_Desvio'] = df['NDVI_Desvio'].bfill().ffill()
