import re

def extrair_ndvi_da_pasta(caminho_pasta):
    arquivos_tiff = glob.glob(os.path.join(caminho_pasta, '*.tiff'))
    resultados = []
    for caminho in arquivos_tiff:
        nome_arquivo = os.path.basename(caminho)
        # Pega a data (AAAA-MM-DD)
        match_data = re.search(r'\d{4}-\d{2}-\d{2}', nome_arquivo)
        
        if match_data:
            data_str = match_data.group()
            with rasterio.open(caminho) as src:
                matriz = src.read(1)
                # Filtra apenas valores válidos de NDVI
                validos = matriz[(matriz >= -1) & (matriz <= 1)]
                if len(validos) > 0:
                    resultados.append({
                        'Data': data_str,
                        'NDVI_Medio': np.mean(validos),
                        'NDVI_Desvio': np.std(validos),
                        'Qtd_Pixels': len(validos)})
    df = pd.DataFrame(resultados)
    if not df.empty:
        df['Data'] = pd.to_datetime(df['Data'])
        df = df.sort_values('Data').set_index('Data')
    return df

